{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://smith-match.invalid/reference-cases.schema.json",
  "title": "Smith Match alternate-formulation reference cases",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "cases"],
  "properties": {
    "schemaVersion": { "const": 1 },
    "cases": {
      "type": "array",
      "minItems": 10,
      "items": { "$ref": "#/$defs/case" }
    }
  },
  "$defs": {
    "complex": {
      "type": "object",
      "additionalProperties": false,
      "required": ["re", "im"],
      "properties": {
        "re": { "type": "number" },
        "im": { "type": "number" }
      }
    },
    "tolerance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["absolute", "relative"],
      "properties": {
        "absolute": { "type": "number", "exclusiveMinimum": 0 },
        "relative": { "type": "number", "exclusiveMinimum": 0 }
      }
    },
    "confirmation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["title", "provider", "locator", "scope"],
      "properties": {
        "title": { "type": "string", "minLength": 1 },
        "provider": { "type": "string", "minLength": 1 },
        "locator": { "type": "string", "minLength": 1 },
        "scope": { "type": "string", "minLength": 1 }
      }
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["title", "provider", "method", "locator", "convention"],
      "properties": {
        "title": { "type": "string", "minLength": 1 },
        "provider": { "type": "string", "minLength": 1 },
        "method": { "type": "string", "minLength": 1 },
        "locator": { "type": "string", "minLength": 1 },
        "convention": { "type": "string", "minLength": 1 },
        "externalConfirmation": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/confirmation" }
        }
      }
    },
    "termination": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "stubLengthWavelengths",
        "stubLengthMeters",
        "resultingNormalizedAdmittance",
        "resultingReflectionCoefficient",
        "residualReflectionMagnitude"
      ],
      "properties": {
        "stubLengthWavelengths": { "type": "number", "minimum": 0, "exclusiveMaximum": 0.5 },
        "stubLengthMeters": { "type": "number", "minimum": 0 },
        "resultingNormalizedAdmittance": { "$ref": "#/$defs/complex" },
        "resultingReflectionCoefficient": { "$ref": "#/$defs/complex" },
        "residualReflectionMagnitude": { "type": "number", "minimum": 0, "maximum": 1e-8 }
      }
    },
    "solution": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "feedlineDistanceWavelengths",
        "feedlineDistanceMeters",
        "junctionNormalizedImpedance",
        "junctionNormalizedAdmittance",
        "requiredStubNormalizedSusceptance",
        "terminations"
      ],
      "properties": {
        "feedlineDistanceWavelengths": { "type": "number", "minimum": 0, "exclusiveMaximum": 0.5 },
        "feedlineDistanceMeters": { "type": "number", "minimum": 0 },
        "junctionNormalizedImpedance": { "$ref": "#/$defs/complex" },
        "junctionNormalizedAdmittance": { "$ref": "#/$defs/complex" },
        "requiredStubNormalizedSusceptance": { "type": "number" },
        "terminations": {
          "type": "object",
          "additionalProperties": false,
          "required": ["open", "short"],
          "properties": {
            "open": { "$ref": "#/$defs/termination" },
            "short": { "$ref": "#/$defs/termination" }
          }
        }
      }
    },
    "case": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "input", "tolerance", "source", "equations", "expected"],
      "properties": {
        "id": { "type": "string", "pattern": "^[a-z0-9-]+$" },
        "input": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "resistanceOhms",
            "reactanceOhms",
            "characteristicImpedanceOhms",
            "frequencyHz",
            "velocityFactor"
          ],
          "properties": {
            "resistanceOhms": { "type": "number", "exclusiveMinimum": 0 },
            "reactanceOhms": { "type": "number" },
            "characteristicImpedanceOhms": { "type": "number", "exclusiveMinimum": 0 },
            "frequencyHz": { "type": "number", "exclusiveMinimum": 0 },
            "velocityFactor": { "type": "number", "exclusiveMinimum": 0, "maximum": 1 }
          }
        },
        "tolerance": { "$ref": "#/$defs/tolerance" },
        "source": { "$ref": "#/$defs/source" },
        "equations": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "type": "string", "pattern": "^RF-[A-Z]+-[0-9]{3}$" }
        },
        "expected": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "normalizedLoadImpedance",
            "loadReflectionCoefficient",
            "wavelengthMeters",
            "solutions"
          ],
          "properties": {
            "normalizedLoadImpedance": { "$ref": "#/$defs/complex" },
            "loadReflectionCoefficient": { "$ref": "#/$defs/complex" },
            "wavelengthMeters": { "type": "number", "exclusiveMinimum": 0 },
            "solutions": {
              "type": "array",
              "minItems": 2,
              "maxItems": 2,
              "items": { "$ref": "#/$defs/solution" }
            }
          }
        }
      }
    }
  }
}
